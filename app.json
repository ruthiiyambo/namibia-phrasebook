{
  "expo": {
    "name": "Namibia Phrasebook",
    "description": "A travel phrasebook for essential Namibia languages, with searchable phrases and pronunciation help.",
    "slug": "namibia-phrasebook",
    "scheme": "namibia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFBF5",
    "primaryColor": "#1B4332",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.namibiaphrasebook.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.namibiaphrasebook.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1B4332",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83ce5437-e86b-43c9-86ad-c2e2194c8520"
      }
    }
  }
}
